{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/2bbb/bbb.dmx/schemas/bbb.dmx.curve.v1.schema.json",
  "title": "bbb.dmx curve rules v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "rules"
  ],
  "properties": {
    "schema": {
      "const": "bbb.dmx.curve.v1"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "universe": {
            "type": "integer",
            "minimum": 0
          },
          "start": {
            "type": "integer",
            "minimum": 1,
            "maximum": 512
          },
          "count": {
            "type": "integer",
            "minimum": 0,
            "maximum": 512
          },
          "end": {
            "type": "integer",
            "minimum": 1,
            "maximum": 512
          },
          "curve": {
            "enum": [
              "linear",
              "gamma",
              "invert",
              "threshold",
              "points"
            ]
          },
          "gamma": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "threshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "points": {
            "type": "array",
            "items": {
              "type": "array",
              "prefixItems": [
                {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              ],
              "minItems": 2,
              "maxItems": 2
            },
            "minItems": 1
          }
        }
      },
      "minItems": 1
    }
  }
}
